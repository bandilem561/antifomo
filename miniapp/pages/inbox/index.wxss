  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.research-rank-name {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.45;
  font-weight: 600;
  color: var(--af-text-hero);
}

.research-rank-score {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.84);
  color: rgba(255, 255, 255, 0.92);
  font-size: 17rpx;
  line-height: 1;
  flex-shrink: 0;
}

.research-rank-reason {
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.58;
  color: var(--af-text-main);
}

.research-rank-links {
  margin-top: 12rpx;
  display: grid;
  gap: 8rpx;
}

.compact-evidence-link {
  padding: 14rpx 16rpx;
}

.evidence-link-chip {
  width: 100%;
  text-align: left;
  border-radius: 18rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.2);
  background: rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
}

.evidence-link-chip-static {
  opacity: 0.92;
}

.evidence-link-title {
  font-size: 20rpx;
  line-height: 1.5;
  color: var(--af-text-main);
  word-break: break-word;
  white-space: normal;
}

.evidence-link-tier {
  margin-top: 8rpx;
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(14, 165, 233, 0.1);
  color: #0284c7;
  font-size: 17rpx;
  line-height: 1;
}

.evidence-link-meta {
  margin-top: 6rpx;
  font-size: 18rpx;
  line-height: 1.45;
  color: var(--af-text-muted);
}

.research-source + .research-source {
  margin-top: 12rpx;
}

.research-source {
  padding: 16rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.16);
  background: rgba(123, 139, 168, 0.06);
}

.research-source-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.research-source-domain {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.16);
  background: rgba(255, 255, 255, 0.68);
  color: var(--af-text-secondary);
  font-size: 18rpx;
}

.research-source-title {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.42;
  font-weight: 600;
  color: var(--af-text-hero);
}

.research-source-snippet {
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.58;
  color: var(--af-text-muted);
}

.research-skeleton {
  margin-top: 16rpx;
}
