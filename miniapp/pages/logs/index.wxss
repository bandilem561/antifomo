.panel {
  margin-top: 22rpx;
  padding: 24rpx;
}

.tip {
  margin-top: 10rpx;
  font-size: 22rpx;
}

.event-list {
  margin-top: 14rpx;
}

.event-item {
  margin-top: 12rpx;
  padding: 18rpx;
  border-color: rgba(123, 139, 168, 0.28);
  background: rgba(123, 139, 168, 0.08);
}

.event-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.event-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #eff6ff;
}

.event-time {
  color: #9ab0cf;
  font-size: 22rpx;
}

.event-payload {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #c8d7ef;
  line-height: 1.6;
  word-break: break-all;
}

.replay-box {
  margin-top: 20rpx;
  border-color: rgba(127, 216, 255, 0.35);
}

.replay-name {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #f1f8ff;
}
