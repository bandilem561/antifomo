.card {
  padding: 22rpx;
}

.field-label {
  font-size: 21rpx;
  color: var(--af-text-muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.field-input {
  margin-top: 12rpx;
}

.helper {
  margin-top: 12rpx;
  font-size: 19rpx;
  line-height: 1.56;
  color: var(--af-text-muted);
}

.merge-preview-card {
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.04), rgba(123, 139, 168, 0.08));
}

.page.pref-theme-light .merge-preview-card {
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.92), rgba(244, 248, 255, 0.88));
}

.merge-preview-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.merge-preview-title {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.34;
  font-weight: 600;
  color: var(--af-text-hero);
}

.merge-preview-chip-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.merge-preview-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.merge-preview-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.merge-preview-index {
  width: 26rpx;
  font-size: 18rpx;
  line-height: 1.5;
  color: var(--af-kicker);
  flex-shrink: 0;
}

.merge-preview-item-title {
  flex: 1;
  min-width: 0;
  font-size: 20rpx;
  line-height: 1.54;
  color: var(--af-text-main);
}

.merge-preview-more {
  margin-left: 36rpx;
  font-size: 20rpx;
  color: var(--af-text-muted);
}

.selected-card {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.18);
  background: rgba(123, 139, 168, 0.08);
}

.page.pref-theme-light .selected-card {
  background: rgba(255, 255, 255, 0.72);
}

.selected-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.selected-title {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.42;
  font-weight: 600;
  color: var(--af-text-hero);
}

.meta {
  margin-top: 8rpx;
  color: var(--af-text-muted);
  font-size: 20rpx;
}

.action-card {
  padding-top: 18rpx;
}

.action-row {
  display: flex;
  gap: 12rpx;
}

.action-row .btn {
  flex: 1;
}
