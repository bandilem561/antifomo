.card {
  padding: 22rpx;
}

.hint-copy {
  margin-top: 8rpx;
  font-size: 19rpx;
  line-height: 1.56;
  color: var(--af-text-muted);
}

.main-card {
  border-color: rgba(127, 216, 255, 0.3);
  background:
    radial-gradient(460rpx 220rpx at 8% 0%, rgba(96, 165, 250, 0.16), transparent 58%),
    linear-gradient(160deg, rgba(17, 23, 35, 0.96), rgba(13, 18, 27, 0.98));
}

.page.pref-theme-light .main-card {
  background:
    radial-gradient(460rpx 220rpx at 8% 0%, rgba(96, 165, 250, 0.12), transparent 58%),
    linear-gradient(160deg, rgba(255, 255, 255, 0.96), rgba(244, 248, 255, 0.98));
}

.top-line {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.score {
  border-radius: 999rpx;
  border: 1rpx solid rgba(127, 216, 255, 0.42);
  background: rgba(14, 76, 107, 0.35);
  color: #b7ebff;
  padding: 8rpx 14rpx;
  font-size: 19rpx;
}

.title {
  margin-top: 12rpx;
  font-size: 33rpx;
  font-weight: 600;
  line-height: 1.34;
  letter-spacing: -0.02em;
  color: #f2f7ff;
}

.meta {
  margin-top: 10rpx;
  color: #8f9eb7;
  font-size: 21rpx;
}

.link {
  margin-top: 14rpx;
  min-height: 60rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.18);
  background: rgba(123, 139, 168, 0.08);
  color: #7fd8ff;
  font-size: 20rpx;
}

.link-inline {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.page.pref-theme-light .link {
  color: #2563eb;
}

.tag-wrap {
  margin-top: 12rpx;
}

.chip-ghost {
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  border-color: rgba(127, 216, 255, 0.3);
  background: rgba(79, 162, 218, 0.14);
  color: #bfe7ff;
}

.label {
  font-size: 21rpx;
  color: #9eb0ce;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.view-tabs {
  display: flex;
  gap: 10rpx;
  margin-bottom: 16rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(123, 139, 168, 0.08);
  border: 1rpx solid rgba(123, 139, 168, 0.16);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
}

.view-stage {
  position: relative;
  transform-origin: 50% 20%;
}

.view-stage-enter {
  animation: item-view-enter 280ms cubic-bezier(0.22, 0.8, 0.22, 1);
}

.view-tab {
  flex: 1;
  min-height: 68rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.22);
  background: transparent;
  color: #9eb0ce;
  font-size: 20rpx;
  line-height: 68rpx;
  text-align: center;
}

.view-tab-on {
  border-color: rgba(127, 216, 255, 0.38);
  background: linear-gradient(180deg, rgba(110, 202, 255, 0.32) 0%, rgba(61, 121, 197, 0.3) 100%);
  color: #eff6ff;
}

.page.pref-theme-light .view-tab {
  color: #64748b;
}

.page.pref-theme-light .view-tab-on {
  color: #0f172a;
}

.content {
  margin-top: 12rpx;
  line-height: 1.7;
  color: #d6e1f4;
  font-size: 20rpx;
}

.original-wrap {
  margin-top: 12rpx;
  border-radius: 24rpx;
  background: rgba(12, 18, 32, 0.2);
  border: 1rpx solid rgba(123, 139, 168, 0.16);
  padding: 18rpx 20rpx;
}

.original-content {
  margin-top: 0;
  white-space: pre-wrap;
  word-break: break-word;
}

.page.pref-theme-light .original-wrap,
.page.pref-theme-light .key-paragraph-card,
.page.pref-theme-light .insight-card {
  background: rgba(255, 255, 255, 0.74);
}

.key-paragraph-card {
  margin-top: 12rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.2);
  background: rgba(123, 139, 168, 0.08);
  padding: 18rpx 20rpx;
  box-shadow:
    0 16rpx 36rpx rgba(4, 10, 28, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
}

.key-paragraph {
  margin-top: 0;
}

.segment-hit {
  padding: 0 4rpx;
  border-radius: 10rpx;
  background: rgba(127, 216, 255, 0.22);
  color: #f6fbff;
}

.page.pref-theme-light .segment-hit {
  color: #0f172a;
}

.suggestion {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #eff6ff;
}

.reason {
  margin-top: 8rpx;
  color: #9db0cd;
  font-size: 21rpx;
}

.page.pref-theme-light .reason,
.page.pref-theme-light .meta,
.page.pref-theme-light .label {
  color: #64748b;
}

.insight-card {
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(123, 139, 168, 0.08);
  border: 1rpx solid rgba(123, 139, 168, 0.2);
}

.insight-preview-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(160deg, rgba(18, 27, 40, 0.9), rgba(14, 21, 33, 0.96));
  border: 1rpx solid rgba(123, 139, 168, 0.18);
  box-shadow:
    0 18rpx 44rpx rgba(4, 10, 28, 0.16),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.page.pref-theme-light .insight-preview-card {
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.94), rgba(244, 248, 255, 0.98));
}

.insight-preview-kicker {
  font-size: 18rpx;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #8fd8ff;
}

.insight-preview-title {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.26;
  font-weight: 700;
  color: #eff6ff;
}

.page.pref-theme-light .insight-preview-title {
  color: #0f172a;
}

.insight-preview-copy {
  margin-top: 12rpx;
}

.insight-title {
  font-size: 28rpx;
  line-height: 1.22;
  font-weight: 700;
  color: #eff6ff;
}

.insight-subtitle {
  font-size: 19rpx;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #8fb7dc;
}

.msg {
  margin-top: 12rpx;
  font-size: 19rpx;
}

.action-grid {
  margin-top: 8rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.action-grid .btn,
.section .btn {
  padding: 0 18rpx;
  min-height: 80rpx;
  transition: transform 160ms ease, box-shadow 180ms ease, opacity 160ms ease;
}

.action-grid .btn:active,
.section .btn:active,
.insight-sheet-close:active,
.link:active {
  transform: translate3d(0, 2rpx, 0) scale(0.985);
  opacity: 0.92;
}

.insight-sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(7, 10, 18, 0);
  backdrop-filter: blur(0rpx);
  transition: all 220ms ease;
  z-index: 18;
}

.insight-sheet-mask-on {
  background: rgba(7, 10, 18, 0.42);
  backdrop-filter: blur(10rpx);
}

.insight-sheet {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 18rpx;
  max-height: 78vh;
  padding: 18rpx 18rpx 20rpx;
  border-radius: 32rpx;
  background:
    linear-gradient(160deg, rgba(17, 23, 35, 0.98), rgba(12, 18, 28, 0.99));
  border: 1rpx solid rgba(123, 139, 168, 0.2);
  box-shadow:
    0 26rpx 70rpx rgba(3, 8, 20, 0.38),
    inset 0 1rpx 0 rgba(173, 191, 224, 0.08);
  transform: translate3d(0, 100%, 0) scale(0.98);
  opacity: 0;
  transition: transform 260ms cubic-bezier(0.22, 0.8, 0.22, 1), opacity 220ms ease;
  z-index: 19;
  box-sizing: border-box;
}

.page.pref-theme-light .insight-sheet {
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.98), rgba(244, 248, 255, 0.99));
  box-shadow:
    0 24rpx 60rpx rgba(15, 23, 42, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.68);
}

.insight-sheet-on {
  transform: translate3d(0, 0, 0) scale(1);
  opacity: 1;
}

.insight-sheet-handle {
  width: 76rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.42);
  margin: 0 auto 18rpx;
}

.insight-sheet-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.insight-sheet-title {
  margin-top: 8rpx;
  font-size: 32rpx;
  line-height: 1.28;
  font-weight: 700;
  color: #eff6ff;
}

.page.pref-theme-light .insight-sheet-title {
  color: #0f172a;
}

.insight-sheet-close {
  min-width: 72rpx;
  min-height: 72rpx;
  padding: 0;
  border-radius: 999rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.22);
  background: rgba(123, 139, 168, 0.08);
  color: #d9e5f5;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.page.pref-theme-light .insight-sheet-close {
  color: #475569;
}

.insight-sheet-body {
  margin-top: 18rpx;
  max-height: 46vh;
}

.insight-sheet-actions {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.btn-like-on {
  color: #03110c;
  background: linear-gradient(180deg, #7df0c3 0%, #34d399 100%);
}

.btn-ignore-on {
  color: #e8eefb;
  background: rgba(123, 139, 168, 0.28);
}

.btn-save-on {
  color: #051224;
  background: linear-gradient(180deg, #8fd3ff 0%, #5fbeff 100%);
}

@keyframes item-view-enter {
  0% {
    opacity: 0;
    transform: translate3d(0, 16rpx, 0) scale(0.985);
    filter: blur(4rpx);
  }
  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    filter: blur(0);
  }
}
