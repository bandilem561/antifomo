.card {
  padding: 22rpx;
}

.hero-card {
  background:
    radial-gradient(420rpx 220rpx at 8% 0%, rgba(96, 165, 250, 0.14), transparent 58%),
    linear-gradient(160deg, rgba(17, 23, 35, 0.96), rgba(13, 18, 27, 0.98));
}

.page.pref-theme-light .hero-card {
  background:
    radial-gradient(420rpx 220rpx at 8% 0%, rgba(96, 165, 250, 0.12), transparent 58%),
    linear-gradient(160deg, rgba(255, 255, 255, 0.96), rgba(244, 248, 255, 0.98));
}

.meta {
  margin-top: 10rpx;
  color: var(--af-text-muted);
  font-size: 21rpx;
}

.toggle-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.field-label {
  font-size: 21rpx;
  color: var(--af-text-muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.field-input {
  margin-top: 12rpx;
}

.entry-textarea {
  width: 100%;
  min-height: 420rpx;
  margin-top: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  border: 1rpx solid var(--af-input-border);
  background: var(--af-input-bg);
  color: var(--af-input-text);
  font-size: 23rpx;
  line-height: 1.66;
}

.action-card {
  padding-top: 18rpx;
}

.action-row {
  display: flex;
  gap: 12rpx;
}

.action-row .btn {
  flex: 1;
}
