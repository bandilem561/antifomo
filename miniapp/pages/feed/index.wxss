.hero-panel {
  margin-top: 10rpx;
}

.hero-stats {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
  padding: 16rpx;
}

.stat-item {
  flex: 1;
  min-width: 0;
  padding: 14rpx 12rpx;
  border-radius: 18rpx;
  background: rgba(123, 139, 168, 0.08);
  border: 1rpx solid rgba(123, 139, 168, 0.22);
}

.stat-label {
  font-size: 18rpx;
  color: var(--af-text-muted);
}

.stat-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 600;
  color: var(--af-text-hero);
}

.mode-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.mode-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 60rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(123, 139, 168, 0.1);
  border: 1rpx solid rgba(123, 139, 168, 0.28);
  color: var(--af-text-secondary);
  font-size: 21rpx;
}

.mode-on {
  background: linear-gradient(180deg, #f8fbff 0%, #dce4f4 100%);
  color: #0b0f14;
  border-color: rgba(255, 255, 255, 0.6);
}

.page.pref-theme-light .mode-on {
  background: linear-gradient(180deg, #2188ff 0%, #0071e3 100%);
  color: #f8fbff;
}

.mode-link {
  border-style: dashed;
}

.focus-goal {
  margin-top: 10rpx;
  font-size: 21rpx;
}

.latest-run {
  margin-top: 22rpx;
  padding: 22rpx;
  background:
    radial-gradient(520rpx 220rpx at 8% 0%, rgba(96, 165, 250, 0.18), transparent 58%),
    linear-gradient(160deg, rgba(15, 22, 34, 0.88), rgba(13, 18, 28, 0.96));
}

.page.pref-theme-light .latest-run {
  background:
    radial-gradient(520rpx 220rpx at 8% 0%, rgba(96, 165, 250, 0.14), transparent 58%),
    linear-gradient(160deg, rgba(255, 255, 255, 0.92), rgba(244, 248, 255, 0.98));
}

.latest-run-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.latest-run-copy {
  flex: 1;
  min-width: 0;
}

.latest-run-kicker,
.latest-run-section {
  font-size: 18rpx;
  line-height: 1.2;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--af-kicker);
}

.latest-run-title {
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.16;
  font-weight: 600;
  color: var(--af-text-hero);
}

.latest-run-sub {
  margin-top: 10rpx;
  font-size: 21rpx;
  line-height: 1.52;
  color: var(--af-text-secondary);
}

.latest-run-btn {
  min-width: 150rpx;
  min-height: 62rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.22);
  background: rgba(255, 255, 255, 0.08);
  color: var(--af-text-hero);
  font-size: 20rpx;
  box-sizing: border-box;
}

.page.pref-theme-light .latest-run-btn {
  background: rgba(255, 255, 255, 0.92);
  color: #0f172a;
}

.latest-run-metrics {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.latest-run-metric {
  min-width: 0;
  padding: 16rpx 14rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.18);
  background: rgba(255, 255, 255, 0.05);
}

.page.pref-theme-light .latest-run-metric {
  background: rgba(255, 255, 255, 0.74);
}

.latest-run-metric-label {
  font-size: 18rpx;
  color: var(--af-text-muted);
}

.latest-run-metric-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 600;
  color: var(--af-text-hero);
}

.latest-run-section {
  margin-top: 18rpx;
}

.latest-run-item {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.16);
  background: rgba(255, 255, 255, 0.04);
}

.page.pref-theme-light .latest-run-item {
  background: rgba(255, 255, 255, 0.64);
}

.latest-run-item-top {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.latest-run-item-source {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.18);
  background: rgba(123, 139, 168, 0.1);
  color: var(--af-text-secondary);
  font-size: 18rpx;
}

.latest-run-item-title {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.38;
  font-weight: 600;
  color: var(--af-text-main);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.latest-run-item-summary {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.55;
  color: var(--af-text-muted);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.latest-run-empty {
  margin-top: 16rpx;
  font-size: 21rpx;
  line-height: 1.52;
  color: var(--af-text-muted);
}

.swipe-copy {
  margin-top: 18rpx;
  text-align: center;
}

.swipe-main {
  font-size: 23rpx;
  font-weight: 600;
  color: var(--af-text-hero);
}

.swipe-sub {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--af-text-muted);
}

.deck-stage {
  position: relative;
  margin-top: 20rpx;
  min-height: 820rpx;
}

.ghost-card {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  top: 40rpx;
  z-index: 1;
  padding: 26rpx 24rpx 22rpx;
  opacity: 0.58;
  transform: scale(0.95);
  filter: saturate(0.7);
}

.ghost-kicker {
  font-size: 18rpx;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--af-text-muted);
}

.ghost-title {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.26;
  font-weight: 600;
  color: var(--af-text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ghost-summary {
  margin-top: 12rpx;
  font-size: 20rpx;
  line-height: 1.55;
  color: var(--af-text-muted);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.swipe-badge {
  position: absolute;
  top: 180rpx;
  width: 228rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 24rpx;
  backdrop-filter: blur(24rpx);
  opacity: 0.28;
  transform: translateY(16rpx) scale(0.94);
  transition: all 180ms ease;
  z-index: 3;
}

.swipe-badge-left {
  left: 0;
  border: 1rpx solid rgba(148, 163, 184, 0.3);
  background: rgba(51, 65, 85, 0.34);
}

.swipe-badge-right {
  right: 0;
  border: 1rpx solid rgba(56, 189, 248, 0.34);
  background: rgba(14, 116, 144, 0.3);
}

.badge-on {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.swipe-badge-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #f8fbff;
}

.swipe-badge-sub {
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.45;
  color: rgba(238, 243, 251, 0.78);
}

.story-card {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  z-index: 5;
  overflow: hidden;
}

.story-poster {
  position: relative;
  min-height: 474rpx;
  padding: 24rpx 24rpx 22rpx;
  overflow: hidden;
  background:
    radial-gradient(540rpx 360rpx at 8% 10%, rgba(103, 232, 249, 0.34), transparent 60%),
    radial-gradient(420rpx 360rpx at 92% 18%, rgba(96, 165, 250, 0.2), transparent 58%),
    linear-gradient(160deg, #0f172a 0%, #101827 42%, #0b1220 100%);
}

.page.pref-theme-light .story-poster {
  background:
    radial-gradient(540rpx 360rpx at 8% 10%, rgba(96, 165, 250, 0.24), transparent 60%),
    radial-gradient(420rpx 360rpx at 92% 18%, rgba(56, 189, 248, 0.2), transparent 58%),
    linear-gradient(160deg, #eff5ff 0%, #f6f9ff 42%, #e7f0ff 100%);
}

.poster-glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(28rpx);
  opacity: 0.85;
}

.poster-glow-a {
  width: 280rpx;
  height: 280rpx;
  left: -50rpx;
  top: 80rpx;
  background: rgba(56, 189, 248, 0.26);
}

.poster-glow-b {
  width: 240rpx;
  height: 240rpx;
  right: -20rpx;
  bottom: 40rpx;
  background: rgba(59, 130, 246, 0.22);
}

.poster-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.05) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1rpx, transparent 1rpx);
  background-size: 42rpx 42rpx;
  opacity: 0.28;
}

.poster-topline {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.poster-chip {
  display: inline-flex;
  align-items: center;
  min-height: 50rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.08);
  color: #f8fbff;
  font-size: 19rpx;
  box-sizing: border-box;
}

.page.pref-theme-light .poster-chip {
  border-color: rgba(15, 23, 42, 0.08);
  background: rgba(255, 255, 255, 0.55);
  color: #0f172a;
}

.poster-score.score-high {
  background: rgba(16, 185, 129, 0.16);
  border-color: rgba(16, 185, 129, 0.26);
}

.poster-score.score-mid {
  background: rgba(245, 158, 11, 0.16);
  border-color: rgba(245, 158, 11, 0.24);
}

.poster-score.score-low {
  background: rgba(148, 163, 184, 0.14);
  border-color: rgba(148, 163, 184, 0.24);
}

.poster-bottom {
  position: relative;
  z-index: 2;
  margin-top: 150rpx;
}

.poster-kicker {
  font-size: 18rpx;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(244, 247, 255, 0.72);
}

.page.pref-theme-light .poster-kicker {
  color: rgba(15, 23, 42, 0.56);
}

.poster-title {
  margin-top: 16rpx;
  font-size: 40rpx;
  line-height: 1.18;
  font-weight: 700;
  letter-spacing: -0.04em;
  color: #f8fbff;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.page.pref-theme-light .poster-title {
  color: #0f172a;
}

.poster-summary {
  margin-top: 14rpx;
  font-size: 21rpx;
  line-height: 1.56;
  color: rgba(238, 243, 251, 0.8);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  max-height: 72rpx;
  text-overflow: ellipsis;
}

.page.pref-theme-light .poster-summary {
  color: rgba(30, 41, 59, 0.78);
}

.card-content {
  padding: 18rpx 20rpx 22rpx;
}

.signal-panel {
  margin-top: 10rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(125, 211, 252, 0.18);
  background:
    linear-gradient(160deg, rgba(14, 22, 34, 0.76), rgba(15, 23, 42, 0.92));
}

.page.pref-theme-light .signal-panel {
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.9), rgba(241, 246, 255, 0.96));
  border-color: rgba(96, 165, 250, 0.18);
}

.signal-label {
  font-size: 18rpx;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--af-kicker);
}

.signal-value {
  margin-top: 8rpx;
  font-size: 29rpx;
  line-height: 1.18;
  font-weight: 600;
  color: var(--af-text-hero);
}

.signal-reason {
  margin-top: 8rpx;
  font-size: 19rpx;
  line-height: 1.55;
  color: var(--af-text-secondary);
}

.signal-meta {
  margin-top: 10rpx;
  font-size: 18rpx;
  color: var(--af-text-muted);
}

.knowledge-strip {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.16);
  background: rgba(255, 255, 255, 0.04);
}

.page.pref-theme-light .knowledge-strip {
  background: rgba(255, 255, 255, 0.68);
}

.knowledge-strip-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.knowledge-strip-copy {
  flex: 1;
  min-width: 0;
}

.knowledge-strip-title {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--af-text-hero);
}

.knowledge-strip-sub {
  margin-top: 8rpx;
  font-size: 19rpx;
  line-height: 1.55;
  color: var(--af-text-muted);
}

.knowledge-ghost-btn {
  min-height: 54rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.22);
  background: rgba(123, 139, 168, 0.08);
  color: var(--af-text-secondary);
  font-size: 18rpx;
}

.knowledge-focus-card {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.14);
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.05), rgba(123, 139, 168, 0.06));
}

.knowledge-mini-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.knowledge-mini-title {
  flex: 1;
  min-width: 0;
  font-size: 21rpx;
  line-height: 1.45;
  color: var(--af-text-main);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.knowledge-mini-meta {
  margin-top: 6rpx;
  font-size: 18rpx;
  color: var(--af-text-muted);
}

.knowledge-more-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 38rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(123, 139, 168, 0.12);
  border: 1rpx solid rgba(123, 139, 168, 0.18);
  font-size: 18rpx;
  color: var(--af-text-secondary);
  flex-shrink: 0;
}

.chip-inline {
  margin: 0;
}

.memory-note {
  margin-top: 12rpx;
  font-size: 19rpx;
  line-height: 1.48;
  color: var(--af-text-muted);
}

.action-dock {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.dock-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-width: 0;
  min-height: 122rpx;
  padding: 16rpx 12rpx 14rpx;
  border-radius: 28rpx;
  font-size: 21rpx;
  font-weight: 600;
  box-sizing: border-box;
  text-align: center;
}

.dock-label {
  line-height: 1.34;
}

.dock-primary {
  color: var(--af-btn-primary-text);
  background: linear-gradient(180deg, #f8fbff 0%, #dce4f4 100%);
}

.page.pref-theme-light .dock-primary {
  background: linear-gradient(180deg, #2188ff 0%, #0071e3 100%);
  color: #f8fbff;
}

.dock-secondary {
  color: var(--af-btn-secondary-text);
  background: rgba(123, 139, 168, 0.12);
  border: 1rpx solid rgba(123, 139, 168, 0.26);
}

.dock-secondary-on {
  background: rgba(148, 163, 184, 0.28);
}

.dock-like {
  color: #041421;
  background: linear-gradient(180deg, #8fd3ff 0%, #60a5fa 100%);
}

.dock-like-on {
  color: #03110c;
  background: linear-gradient(180deg, #7df0c3 0%, #34d399 100%);
}

.empty {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  color: var(--af-text-muted);
}

.hint {
  margin-top: 16rpx;
  text-align: center;
  font-size: 20rpx;
}

.daily-brief {
  margin-top: 18rpx;
}

.daily-brief-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.daily-brief-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.latest-run-btn-muted {
  background: rgba(255, 255, 255, 0.08);
}

.page.pref-theme-light .latest-run-btn-muted {
  background: rgba(255, 255, 255, 0.92);
}

.daily-brief-item {
  margin-top: 12rpx;
  border-radius: 26rpx;
  padding: 18rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(123, 139, 168, 0.08));
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.page.pref-theme-light .daily-brief-item {
  background: rgba(255, 255, 255, 0.88);
  border-color: rgba(123, 139, 168, 0.14);
}

.daily-brief-watchlist {
  margin-top: 10rpx;
  border-radius: 22rpx;
  padding: 16rpx 18rpx;
  background: rgba(14, 165, 233, 0.08);
}

.daily-brief-watchlist-summary {
  font-size: 22rpx;
  line-height: 1.55;
  color: var(--af-text-main);
}

.daily-brief-watchlist-meta {
  margin-top: 6rpx;
  font-size: 18rpx;
  color: var(--af-text-muted);
}

.daily-brief-audio-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.daily-brief-audio-hint {
  font-size: 18rpx;
  color: var(--af-text-muted);
}
