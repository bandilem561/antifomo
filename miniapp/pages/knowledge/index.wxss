.card {
  padding: 22rpx;
}

.toolbar {
  padding-bottom: 18rpx;
}

.detail-hero-card,
.overview-card {
  background:
    radial-gradient(420rpx 220rpx at 8% 0%, rgba(96, 165, 250, 0.14), transparent 58%),
    linear-gradient(160deg, rgba(17, 23, 35, 0.96), rgba(13, 18, 27, 0.98));
}

.page.pref-theme-light .detail-hero-card,
.page.pref-theme-light .overview-card {
  background:
    radial-gradient(420rpx 220rpx at 8% 0%, rgba(96, 165, 250, 0.12), transparent 58%),
    linear-gradient(160deg, rgba(255, 255, 255, 0.96), rgba(244, 248, 255, 0.98));
}

.overview-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.overview-metric {
  min-width: 0;
  padding: 16rpx 14rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.18);
  background: rgba(255, 255, 255, 0.05);
}

.page.pref-theme-light .overview-metric {
  background: rgba(255, 255, 255, 0.72);
}

.overview-label {
  font-size: 18rpx;
  color: var(--af-text-muted);
}

.overview-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 600;
  color: var(--af-text-hero);
}

.command-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.command-span {
  grid-column: span 2;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 16rpx;
  min-height: 76rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.24);
  background: rgba(123, 139, 168, 0.08);
}

.search-input {
  flex: 1;
  min-width: 0;
  color: #e7eefb;
  font-size: 21rpx;
}

.page.pref-theme-light .search-input {
  color: #1e293b;
}

.source-scroll {
  width: 100%;
  white-space: nowrap;
}

.source-row {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding-right: 4rpx;
}

.rule-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rule-label {
  font-size: 22rpx;
  color: #9eb0ce;
}

.rule-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.sort-hint {
  margin-top: 12rpx;
  font-size: 19rpx;
  color: #8fa3bf;
}

.selection-strip {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.18);
  background: rgba(255, 255, 255, 0.05);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
}

.page.pref-theme-light .selection-strip {
  background: rgba(255, 255, 255, 0.68);
}

.selection-strip-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--af-text-hero);
}

.selection-strip-sub {
  margin-top: 8rpx;
  font-size: 19rpx;
  line-height: 1.48;
  color: var(--af-text-muted);
}

.merge-preview-card {
  margin-top: 14rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.18);
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.04), rgba(123, 139, 168, 0.08));
}

.page.pref-theme-light .merge-preview-card {
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.92), rgba(244, 248, 255, 0.88));
}

.merge-preview-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.merge-preview-title {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.34;
  font-weight: 600;
  color: var(--af-text-hero);
}

.merge-preview-sub {
  margin-top: 10rpx;
  font-size: 19rpx;
  line-height: 1.56;
  color: var(--af-text-muted);
}

.merge-preview-chip-row {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.merge-preview-list {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.merge-preview-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.merge-preview-index {
  width: 26rpx;
  font-size: 18rpx;
  line-height: 1.5;
  color: var(--af-kicker);
  flex-shrink: 0;
}

.merge-preview-item-title {
  flex: 1;
  min-width: 0;
  font-size: 20rpx;
  line-height: 1.5;
  color: var(--af-text-main);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.merge-preview-more {
  font-size: 18rpx;
  color: var(--af-text-muted);
}

.entry-top,
.list-entry-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.entry-edit-btn {
  flex-shrink: 0;
  min-width: 0;
}

.entry-edit-btn.btn {
  min-height: 66rpx;
  padding: 0 14rpx;
}

.entry-input,
.merge-input {
  min-height: 72rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.24);
  background: rgba(123, 139, 168, 0.08);
  padding: 0 18rpx;
  font-size: 21rpx;
}

.section-gap-sm {
  margin-top: 12rpx;
}

.entry-textarea {
  margin-top: 16rpx;
  min-height: 320rpx;
  width: 100%;
  border-radius: 24rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.24);
  background: rgba(123, 139, 168, 0.08);
  color: #d6e1f4;
  font-size: 21rpx;
  line-height: 1.72;
  padding: 18rpx;
  box-sizing: border-box;
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.action-row .btn {
  flex: 1 1 0;
  min-width: 0;
  min-height: 76rpx;
}

.research-brief-card {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.18);
  background: rgba(255, 255, 255, 0.05);
}

.research-evidence-card {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.18);
  background: rgba(241, 245, 249, 0.7);
}

.research-evidence-card.evidence-strong {
  border-color: rgba(16, 185, 129, 0.22);
  background: rgba(236, 253, 245, 0.82);
}

.research-evidence-card.evidence-provisional {
  border-color: rgba(245, 158, 11, 0.22);
  background: rgba(255, 251, 235, 0.82);
}

.research-evidence-title {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--af-text-hero);
}

.research-evidence-note {
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.56;
  color: var(--af-text-main);
}

.research-evidence-flags {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.research-evidence-flag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  font-size: 16rpx;
  color: var(--af-text-muted);
}

.page.pref-theme-light .research-brief-card,
.page.pref-theme-light .research-panel,
.page.pref-theme-light .research-angle-card {
  background: rgba(255, 255, 255, 0.72);
}

.research-angle-card {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(96, 165, 250, 0.18);
  background: rgba(96, 165, 250, 0.08);
  color: var(--af-text-main);
  font-size: 20rpx;
  line-height: 1.62;
}

.research-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.research-panel {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.18);
  background: rgba(255, 255, 255, 0.05);
}

.research-panel-title {
  font-size: 19rpx;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--af-text-muted);
}

.research-bullet {
  margin-top: 10rpx;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.research-bullet-dot {
  margin-top: 12rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(96, 165, 250, 0.9);
  flex-shrink: 0;
}

.research-bullet-text {
  flex: 1;
  min-width: 0;
  color: var(--af-text-main);
  font-size: 20rpx;
  line-height: 1.58;
}

.research-rank-item + .research-rank-item {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(123, 139, 168, 0.14);
}

.research-rank-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.research-rank-name {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.42;
  color: var(--af-text-hero);
  font-weight: 600;
}

.research-rank-score {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.08);
  color: var(--af-text-muted);
  font-size: 18rpx;
}

.research-rank-reason {
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.58;
  color: var(--af-text-main);
}

.score-factor-list {
  margin-top: 12rpx;
  display: grid;
  gap: 8rpx;
}

.score-factor-card {
  border-radius: 16rpx;
  padding: 14rpx 16rpx;
  background: rgba(248, 250, 252, 0.9);
  border: 1rpx solid rgba(123, 139, 168, 0.14);
}

.score-factor-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.score-factor-label {
  flex: 1;
  font-size: 18rpx;
  line-height: 1.45;
  font-weight: 600;
  color: var(--af-text-main);
}

.score-factor-badge {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  font-size: 16rpx;
  line-height: 1;
}

.score-factor-positive {
  background: rgba(16, 185, 129, 0.12);
  color: #047857;
}

.score-factor-negative {
  background: rgba(239, 68, 68, 0.12);
  color: #b91c1c;
}

.score-factor-neutral {
  background: rgba(148, 163, 184, 0.14);
  color: #475569;
}

.score-factor-note {
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.55;
  color: var(--af-text-muted);
}

.research-rank-links {
  margin-top: 12rpx;
  display: grid;
  gap: 8rpx;
}

.compact-evidence-link {
  width: 100%;
  padding: 14rpx 16rpx;
  box-sizing: border-box;
}

.evidence-link-chip {
  text-align: left;
  border-radius: 18rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.2);
  background: rgba(255, 255, 255, 0.72);
}

.evidence-link-title {
  font-size: 20rpx;
  line-height: 1.5;
  color: var(--af-text-main);
}

.evidence-link-tier {
  margin-top: 8rpx;
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(14, 165, 233, 0.1);
  color: #0284c7;
  font-size: 17rpx;
  line-height: 1;
}

.evidence-link-meta {
  margin-top: 6rpx;
  font-size: 18rpx;
  line-height: 1.45;
  color: var(--af-text-muted);
}

.toolbar .sort-hint {
  margin-top: 14rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.28;
  letter-spacing: -0.02em;
  color: #f2f7ff;
}

.list-title {
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.35;
  color: #f2f7ff;
}

.meta {
  margin-top: 10rpx;
  color: #8f9eb7;
  font-size: 21rpx;
}

.label {
  font-size: 21rpx;
  color: #9eb0ce;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.content {
  margin-top: 12rpx;
  line-height: 1.72;
  color: #d6e1f4;
  font-size: 20rpx;
}

.preview {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.list-card {
  border-color: rgba(123, 139, 168, 0.22);
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.04), rgba(123, 139, 168, 0.08));
  box-shadow:
    0 12rpx 28rpx rgba(3, 8, 20, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
}

.page.pref-theme-light .list-card {
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.94), rgba(244, 248, 255, 0.9));
}

.list-card-on {
  border-color: rgba(127, 216, 255, 0.5);
  box-shadow: 0 0 0 2rpx rgba(127, 216, 255, 0.18);
}

.related-card {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.24);
  background: rgba(123, 139, 168, 0.08);
}

.entry-action-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}
