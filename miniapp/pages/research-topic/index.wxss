.topic-notes {
  margin-top: 14rpx;
  font-size: 21rpx;
  line-height: 1.6;
  color: var(--af-text-main);
}

.topic-actions {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.topic-message {
  margin-top: 14rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: var(--af-text-muted);
}

.facet-grid {
  margin-top: 16rpx;
  display: grid;
  gap: 12rpx;
}

.facet-field {
  border-radius: 20rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.22);
  background: rgba(255, 255, 255, 0.08);
  padding: 18rpx 20rpx;
}

.page.pref-theme-light .facet-field {
  background: rgba(255, 255, 255, 0.82);
}

.facet-label {
  font-size: 18rpx;
  color: var(--af-text-muted);
}

.facet-value {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.35;
  color: var(--af-text-main);
}

.compare-summary-list {
  margin-top: 18rpx;
  display: grid;
  gap: 10rpx;
}

.compare-summary-item {
  display: flex;
  gap: 10rpx;
  font-size: 20rpx;
  line-height: 1.55;
  color: var(--af-text-main);
}

.compare-summary-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 11rpx;
  border-radius: 999rpx;
  background: rgba(14, 165, 233, 0.8);
}

.compare-grid {
  display: grid;
  gap: 16rpx;
}

.compare-card-title {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 600;
  color: var(--af-text-hero);
}

.compare-card-time {
  margin-top: 8rpx;
  font-size: 18rpx;
  color: var(--af-text-muted);
}

.compare-card-summary {
  margin-top: 14rpx;
  font-size: 21rpx;
  line-height: 1.65;
  color: var(--af-text-main);
}

.focus-grid {
  margin-top: 16rpx;
  display: grid;
  gap: 12rpx;
}

.focus-block {
  border-radius: 20rpx;
  padding: 18rpx 18rpx 16rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.page.pref-theme-light .focus-block {
  background: rgba(255, 255, 255, 0.82);
  border-color: rgba(123, 139, 168, 0.18);
}

.focus-block-title {
  font-size: 18rpx;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--af-text-subtle);
}

.focus-bullet {
  margin-top: 10rpx;
  display: flex;
  gap: 10rpx;
}

.focus-bullet-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.72);
}

.focus-bullet-text {
  flex: 1;
  font-size: 20rpx;
  line-height: 1.6;
  color: var(--af-text-main);
}

.topic-open-btn {
  margin-top: 16rpx;
}

.highlight-grid {
  margin-top: 16rpx;
  display: grid;
  gap: 12rpx;
}

.highlight-card {
  border-radius: 20rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.page.pref-theme-light .highlight-card {
  background: rgba(255, 255, 255, 0.82);
  border-color: rgba(123, 139, 168, 0.18);
}

.highlight-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--af-text-hero);
}

.evidence-link-group {
  margin-top: 16rpx;
  display: grid;
  gap: 10rpx;
}

.evidence-link-kicker {
  font-size: 18rpx;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--af-text-subtle);
}

.evidence-link-chip {
  width: 100%;
  text-align: left;
  border-radius: 18rpx;
  border: 1rpx solid rgba(123, 139, 168, 0.2);
  background: rgba(255, 255, 255, 0.72);
  padding: 16rpx 18rpx;
  box-sizing: border-box;
}

.page.pref-theme-light .evidence-link-chip {
  background: rgba(255, 255, 255, 0.9);
}

.evidence-link-title {
  font-size: 20rpx;
  line-height: 1.5;
  color: var(--af-text-main);
}

.evidence-link-tier {
  margin-top: 8rpx;
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(14, 165, 233, 0.1);
  color: #0284c7;
  font-size: 17rpx;
  line-height: 1;
}

.evidence-link-meta {
  margin-top: 6rpx;
  font-size: 18rpx;
  line-height: 1.45;
  color: var(--af-text-muted);
}

.matrix-grid {
  margin-top: 16rpx;
  display: grid;
  gap: 12rpx;
}

.matrix-card {
  border-radius: 22rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.page.pref-theme-light .matrix-card {
  background: rgba(255, 255, 255, 0.82);
  border-color: rgba(123, 139, 168, 0.18);
}

.matrix-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--af-text-hero);
}

.matrix-columns {
  margin-top: 14rpx;
  display: grid;
  gap: 12rpx;
}

.matrix-column {
  border-radius: 18rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.08);
}

.page.pref-theme-light .matrix-column {
  background: rgba(255, 255, 255, 0.76);
}

.matrix-label {
  font-size: 18rpx;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--af-text-subtle);
}

.score-panel-list {
  margin-top: 16rpx;
  display: grid;
  gap: 12rpx;
}

.score-panel-card {
  border-radius: 22rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.page.pref-theme-light .score-panel-card {
  background: rgba(255, 255, 255, 0.82);
  border-color: rgba(123, 139, 168, 0.18);
}

.score-entity-list {
  margin-top: 12rpx;
  display: grid;
  gap: 12rpx;
}

.score-entity-card {
  border-radius: 18rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.page.pref-theme-light .score-entity-card {
  background: rgba(255, 255, 255, 0.88);
  border-color: rgba(123, 139, 168, 0.18);
}

.score-entity-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.score-entity-name {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.45;
  font-weight: 600;
  color: var(--af-text-hero);
}

.score-chip {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(14, 165, 233, 0.1);
  color: #0284c7;
  font-size: 17rpx;
  line-height: 1;
}

.score-entity-reasoning {
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: var(--af-text-main);
}

.score-factor-list {
  margin-top: 12rpx;
  display: grid;
  gap: 10rpx;
}

.score-factor-card {
  border-radius: 16rpx;
  padding: 14rpx 16rpx;
  background: rgba(248, 250, 252, 0.9);
  border: 1rpx solid rgba(123, 139, 168, 0.14);
}

.score-factor-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.score-factor-label {
  flex: 1;
  font-size: 19rpx;
  line-height: 1.45;
  font-weight: 600;
  color: var(--af-text-main);
}

.score-factor-badge {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  font-size: 16rpx;
  line-height: 1;
}

.score-factor-positive {
  background: rgba(16, 185, 129, 0.12);
  color: #047857;
}

.score-factor-negative {
  background: rgba(239, 68, 68, 0.12);
  color: #b91c1c;
}

.score-factor-neutral {
  background: rgba(148, 163, 184, 0.14);
  color: #475569;
}

.score-factor-note,
.score-factor-empty {
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.55;
  color: var(--af-text-muted);
}

.score-progress-track {
  margin-top: 10rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(226, 232, 240, 0.9);
  overflow: hidden;
}

.score-progress-fill {
  height: 100%;
  border-radius: 999rpx;
}

.score-progress-official {
  background: linear-gradient(90deg, rgba(16, 185, 129, 0.9), rgba(34, 197, 94, 0.92));
}

.score-progress-aggregate {
  background: linear-gradient(90deg, rgba(245, 158, 11, 0.88), rgba(251, 191, 36, 0.92));
}

.score-progress-media {
  background: linear-gradient(90deg, rgba(14, 165, 233, 0.88), rgba(59, 130, 246, 0.92));
}

.diff-evidence-grid {
  margin-top: 16rpx;
  display: grid;
  gap: 12rpx;
}

.diff-evidence-column {
  border-radius: 18rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.08);
}

.page.pref-theme-light .diff-evidence-column {
  background: rgba(255, 255, 255, 0.76);
}

.diff-list {
  margin-top: 16rpx;
  display: grid;
  gap: 14rpx;
}

.diff-card {
  border-radius: 22rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.page.pref-theme-light .diff-card {
  background: rgba(255, 255, 255, 0.82);
  border-color: rgba(123, 139, 168, 0.18);
}

.diff-head {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.diff-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--af-text-hero);
}

.diff-grid {
  margin-top: 16rpx;
  display: grid;
  gap: 12rpx;
}

.diff-column {
  border-radius: 18rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.08);
}

.page.pref-theme-light .diff-column {
  background: rgba(255, 255, 255, 0.76);
}

.diff-label {
  font-size: 18rpx;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--af-text-subtle);
}

.diff-change-title {
  margin-top: 12rpx;
  font-size: 18rpx;
  font-weight: 600;
  color: #10b981;
}

.diff-change-title.remove {
  color: #ef4444;
}

.diff-change-title.rewrite {
  color: #0ea5e9;
}

.diff-change-copy {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: var(--af-text-main);
}

.research-quality-row {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.research-quality-row.compact {
  margin-top: 10rpx;
}

.research-quality-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  line-height: 1;
  background: rgba(148, 163, 184, 0.18);
  color: var(--af-text-muted);
}

.research-quality-chip.quality-high {
  background: rgba(16, 185, 129, 0.16);
  color: #10b981;
}

.research-quality-chip.quality-medium {
  background: rgba(245, 158, 11, 0.16);
  color: #d97706;
}

.research-quality-chip.quality-low {
  background: rgba(148, 163, 184, 0.18);
  color: var(--af-text-muted);
}

.research-quality-chip.quality-neutral {
  background: rgba(255, 255, 255, 0.08);
  color: var(--af-text-muted);
}

.page.pref-theme-light .research-quality-chip.quality-neutral {
  background: rgba(255, 255, 255, 0.82);
}
