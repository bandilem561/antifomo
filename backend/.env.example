# Demo default (zero dependency):
DATABASE_URL=sqlite:///./anti_fomo_demo.db

# If you want PostgreSQL, use for example:
# DATABASE_URL=postgresql+pg8000://postgres:postgres@localhost:5432/anti_fomo_demo

SINGLE_USER_ID=00000000-0000-0000-0000-000000000001
LLM_PROVIDER=mock
LLM_FALLBACK_TO_MOCK=true
OCR_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENAI_VISION_MODEL=
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_SECONDS=120
RESEARCH_LLM_TIMEOUT_SECONDS=180
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_VERIFY_SSL=true
OPENAI_CA_BUNDLE=
STRATEGY_OPENAI_API_KEY=
STRATEGY_OPENAI_BASE_URL=https://api.openai.com/v1
STRATEGY_OPENAI_MODEL=
STRATEGY_OPENAI_TEMPERATURE=0.1
STRATEGY_OPENAI_TIMEOUT_SECONDS=90
URL_FETCH_TIMEOUT_SECONDS=12
RESEARCH_SEARCH_TIMEOUT_SECONDS=10
RESEARCH_MAX_SEARCH_RESULTS=4
RESEARCH_MAX_SOURCES=4
RESEARCH_SOURCE_EXCERPT_CHARS=900
WECHAT_AGENT_AUTO_START=false
PENDING_ITEM_RECOVERY_ENABLED=true
PENDING_ITEM_RECOVERY_INTERVAL_SECONDS=8
PENDING_ITEM_GRACE_SECONDS=10
PROCESSING_STALE_SECONDS=90
PENDING_ITEM_RECOVERY_BATCH_SIZE=12
PENDING_ITEM_MAX_ATTEMPTS=4
WORKBUDDY_WEBHOOK_SECRET=
WORKBUDDY_MODE=auto
WORKBUDDY_SIGNATURE_HEADER=x-workbuddy-signature
WORKBUDDY_TIMESTAMP_HEADER=x-workbuddy-timestamp
WORKBUDDY_SIGNATURE_TTL_SECONDS=300
WORKBUDDY_DEFAULT_CALLBACK_URL=
WORKBUDDY_CALLBACK_BEARER_TOKEN=
WORKBUDDY_CALLBACK_TIMEOUT_SECONDS=12
WORKBUDDY_OFFICIAL_CLI_COMMAND=codebuddy
WORKBUDDY_OFFICIAL_GATEWAY_URL=
WORKBUDDY_OFFICIAL_GATEWAY_HEALTH_URL=
WORKBUDDY_OFFICIAL_GATEWAY_WEBHOOK_URL=
WORKBUDDY_OFFICIAL_GATEWAY_BEARER_TOKEN=
WORKBUDDY_OFFICIAL_PROBE_TIMEOUT_SECONDS=6
WORKBUDDY_OFFICIAL_CLI_TIMEOUT_SECONDS=90

# AIPRO OpenAI-compatible gateway example:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=<YOUR_MODEL_NAME>
#
# Optional strategy/audit model for research pipeline:
# STRATEGY_OPENAI_API_KEY=<YOUR_STRATEGY_MODEL_API_KEY>
# STRATEGY_OPENAI_BASE_URL=https://api.openai.com/v1
# STRATEGY_OPENAI_MODEL=<YOUR_STRATEGY_MODEL_NAME>
